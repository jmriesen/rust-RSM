#killing_the_index_variable_is_an_error.test
f i=1:1:5 w "k" k 
---
,"$ECODE=,M15,\nUndefined index variable
#Killing exclude subscritp or global is error.
s i("a")="foo"
s i("b")="bar"
w "i(a) is ={",i("a"),"}",! 
w "i(b) is ={",i("b"),"}",!
k (i("a")) <- syntax error
w "i(a) is ={",i("a"),"}",! 
w "i(b) is ={",i("b"),"}"
---
i(a) is ={foo}
i(b) is ={bar}
i(a) is ={foo}
i(b) is ={}

